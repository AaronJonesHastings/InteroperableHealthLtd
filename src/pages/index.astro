---
import '../styles/global.css';
import FlipCard from "../components/flipcard.astro";
---

<html>
    <head>
        <title>
            Interoperable Health
        </title>
    </head>

    <body class="bg-teal-50 text-slate-900">
        
        <!-- Title and subheading -->

        <section class="max-w-6xl mx-auto px-6 py-24">

            <h1 class="text-5xl font-bold mb-6">
                Interoperable Health Ltd
            </h1>

            <p class="text-xl mb-8">
                Supporting healthcare organisations through digital transformation,
                interoperability and clinical systems delivery.
            </p>

        </section>

        <!-- Flipcards -->

        <section class="max-w-6xl mx-auto px-6 py-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 p-8">
                <FlipCard
                    frontTitle="About us"
                    backContent="Learn about our goals"
                    href="/about"
                />
                <FlipCard
                    frontTitle="Our Services"
                    backContent="What can we do for you?"
                    href="/services"
                />
                <FlipCard
                    frontTitle="Contact Us"
                    backContent="Get in touch"
                    href="/contact"
                />
            </div>
        </section>
        
        <section class="max-w-6xl mx-auto px-6 py-12">

            <h2 class="text-3xl font-bold mb-8">
                Our Services
            </h2>

            <div class="grid md:grid-cols-3 gap-6">

                <div class="bg-white p-6 rounded-xl shadow">
                    <h3 class="font-semibold text-xl">
                        Clinical Systems
                    </h3>

                    <p>
                        EPR, PAS, pathology and transfusion systems.
                    </p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow">
                    <h3 class="font-semibold text-xl">
                        Interoperability
                    </h3>

                    <p>
                        HL7, FHIR and healthcare integrations.
                    </p>
                </div>

                <div class="bg-white p-6 rounded-xl shadow">
                    <h3 class="font-semibold text-xl">
                        Informatics
                    </h3>

                    <p>
                        Data, reporting and clinical intelligence.
                    </p>
                </div>

            </div>

        </section>

        <section class="max-w-6xl mx-auto px-6 py-12">
            <h2 class="text-3xl font-bold mb-8">
                Publications
            </h2>

            <div class="grid md:grid-cols-3 gap-6">

            <div class="bg-white p-6 rounded-xl shadow">
                <h3 class="font-semibold text-xl">
                    Publications
                </h3>
            </div>
            
        </section>

    </body>
</html>
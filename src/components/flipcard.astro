---
const { frontTitle, backContent, href } = Astro.props;
---

<div class="flip-card w-64 h-40" data-flip-card>
  <div class="flip-card-inner">

    <!-- FRONT -->
    <div class="flip-card-face flip-card-front bg-white border rounded-xl shadow p-4 flex flex-col items-center justify-center">
      <h2 class="text-lg font-bold text-slate-900">
        {frontTitle}
      </h2>
    </div>

    <!-- BACK -->
    <div class="flip-card-face flip-card-back bg-blue-600 text-white border rounded-xl shadow p-4 flex flex-col items-center justify-center text-center">
      <a
        href={href}
        class="bg-white text-blue-700 px-4 py-2 rounded-md font-semibold hover:bg-slate-100 transition"
        data-card-link
      >
        {backContent}
      </a>
    </div>

  </div>
</div>

<style>
  .flip-card {
    perspective: 1000px;
    cursor: pointer;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.6s;
  }

  /* Hover flip (desktop) */
  .flip-card:hover .flip-card-inner {
    transform: rotateY(180deg);
  }

  /* JS-controlled flip (mobile/tap) */
  .flip-card.is-flipped .flip-card-inner {
    transform: rotateY(180deg);
  }

  .flip-card-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    width: 100%;
    height: 100%;
  }

  .flip-card-back {
    transform: rotateY(180deg);
  }

  /* Slight lift effect */
  .flip-card:hover {
    transform: translateY(-4px);
    transition: transform 0.2s ease;
  }
</style>

<script>
  document.querySelectorAll("[data-flip-card]").forEach((card) => {
    const link = card.querySelector("[data-card-link]");

    // Tap / click flips card first
    card.addEventListener("click", (e) => {
      // If user clicked the link → allow navigation
      if (e.target.closest("[data-card-link]")) return;

      // Otherwise toggle flip
      card.classList.toggle("is-flipped");
    });

    // Prevent accidental navigation when card is not flipped
    link.addEventListener("click", (e) => {
      e.stopPropagation();
    });
  });
</script>